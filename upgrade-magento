Emergency/Rollback Commands
21. Rollback
bash
# Restore composer files
cp composer.json.backup composer.json
cp composer.lock.backup composer.lock

# Restore database
mysql -u [username] -p[password] [database] < db_backup.sql

# Restore code
tar -xzf magento_core_backup_*.tar.gz

# Reinstall
php bin/magento setup:install ...


22. Clean Reset
bash
# Complete cleanup
sudo killall -9 php 2>/dev/null
rm -rf generated/* var/di/* var/generation/* var/cache/* var/page_cache/*
php bin/magento cache:flush
php bin/magento maintenance:disable
mysql -u [username] -p -e "DELETE FROM [database].flag WHERE flag_code LIKE '%lock%' OR flag_code LIKE '%setup%';"


